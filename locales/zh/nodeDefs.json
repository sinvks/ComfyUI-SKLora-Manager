{
  "SK_LoraLoaderManager": {
    "display_name": "SK LoRA 加载器",
    "inputs": {
      "model": { "name": "模型", "tooltip": "模型" },
      "clip": { "name": "CLIP", "tooltip": "CLIP" },
      "lora_stack": { "name": "LoRA 堆栈", "tooltip": "LoRA 堆栈 JSON" },
      "selector_mode": { "name": "选择器方案", "tooltip": "选择 LoRA 选择器的显示方案" }
    },
    "outputs": {
      "0": { "name": "模型", "tooltip": "模型" },
      "1": { "name": "CLIP", "tooltip": "CLIP" },
      "2": { "name": "触发词", "tooltip": "触发词" },
      "3": { "name": "已加载 LoRA", "tooltip": "已加载的 LoRA 标签" }
    }
  },
  "SK_LoraMetaExtractor": {
    "display_name": "SK LoRA 元数据提取器",
    "inputs": {
      "image": { "name": "图片", "tooltip": "输入图片" },
      "optimize_output": { "name": "优化输出", "tooltip": "优化输出" },
      "compress_level": { "name": "压缩等级", "tooltip": "压缩等级" }
    },
    "outputs": {
      "0": { "name": "信息 JSON", "tooltip": "元数据 JSON" },
      "1": { "name": "干净图片", "tooltip": "清理后的图片" },
      "2": { "name": "工作流原始", "tooltip": "工作流原始文本" },
      "3": { "name": "提示词原始", "tooltip": "提示词原始文本" }
    }
  },
  "SK_LoraMetaInspector": {
    "display_name": "SK LoRA 元数据查看器",
    "inputs": {
      "info_json": { "name": "信息 JSON", "tooltip": "元数据 JSON" }
    }
  },
  "SK_PromptMatrix_V1": {
    "display_name": "SK 提示词矩阵采样 V1",
    "inputs": {
      "text_input": { "name": "文本输入", "tooltip": "文本输入" },
      "pick_count": { "name": "选取数量", "tooltip": "选取的行/段数，默认为0，表示选取所有" },
      "sort_mode": {
        "name": "排序模式",
        "tooltip": "默认为Sequential（按行/段顺序组合），Random表示按随机顺序组合",
        "options": { "Sequential": "顺序", "Random": "随机" }
      },
      "input_sep": { "name": "输入分隔符", "tooltip": "输入文本的分隔符" },
      "output_sep": { "name": "输出分隔符", "tooltip": "输出文本的分隔符" },
      "seed": { "name": "种子", "tooltip": "随机种子" }
    },
    "outputs": {
      "0": { "name": "字符串", "tooltip": "结果字符串" }
    }
  },
  "SK_PromptMatrix_V2": {
    "display_name": "SK 提示词矩阵采样 V2",
    "inputs": {
      "pick_count": { "name": "选取数量", "tooltip": "选取的行/段数，默认为0，表示选取所有" },
      "sort_mode": {
        "name": "排序模式",
        "tooltip": "默认为Sequential（按行/段顺序组合），Random表示按随机顺序组合",
        "options": { "Sequential": "顺序", "Random": "随机" }
      },
      "input_sep": { "name": "输入分隔符", "tooltip": "输入文本的分隔符" },
      "output_sep": { "name": "输出分隔符", "tooltip": "输出文本的分隔符" },
      "seed": { "name": "种子", "tooltip": "随机种子" },
      "raw_text": { "name": "原始文本", "tooltip": "原始文本" }
    },
    "outputs": {
      "0": { "name": "字符串", "tooltip": "结果字符串" }
    }
  },
  "SK_PromptMatrix_V3": {
    "display_name": "SK 提示词矩阵采样 V3",
    "inputs": {
      "pick_ids": { "name": "选取序号", "tooltip": "所选行/段序号，格式为“1,2,3”，输入0表示所有行/段" },
      "sort_mode": {
        "name": "排序模式",
        "tooltip": "默认为Sequential（按pick_ids顺序组合），Random表示按随机顺序组合",
        "options": { "Sequential": "顺序", "Random": "随机" }
      },
      "input_sep": { "name": "输入分隔符", "tooltip": "输入文本的分隔符" },
      "output_sep": { "name": "输出分隔符", "tooltip": "输出文本的分隔符" },
      "seed": { "name": "种子", "tooltip": "随机种子" },
      "raw_text": { "name": "原始文本", "tooltip": "原始文本" }
    },
    "outputs": {
      "0": { "name": "字符串", "tooltip": "结果字符串" }
    }
  },
  "SK_MergePrompt": {
    "display_name": "SK 合并提示词",
    "inputs": {
      "string_1": { "name": "文本 1", "tooltip": "输入文本 1" },
      "string_2": { "name": "文本 2", "tooltip": "输入文本 2" },
      "string_3": { "name": "文本 3", "tooltip": "输入文本 3" },
      "string_4": { "name": "文本 4", "tooltip": "输入文本 4" },
      "string_5": { "name": "文本 5", "tooltip": "输入文本 5" },
      "string_6": { "name": "文本 6", "tooltip": "输入文本 6" },
      "string_7": { "name": "文本 7", "tooltip": "输入文本 7" },
      "string_8": { "name": "文本 8", "tooltip": "输入文本 8" },
      "string_9": { "name": "文本 9", "tooltip": "输入文本 9" },
      "string_10": { "name": "文本 10", "tooltip": "输入文本 10" },
      "string_11": { "name": "文本 11", "tooltip": "输入文本 11" },
      "string_12": { "name": "文本 12", "tooltip": "输入文本 12" },
      "string_13": { "name": "文本 13", "tooltip": "输入文本 13" },
      "string_14": { "name": "文本 14", "tooltip": "输入文本 14" },
      "string_15": { "name": "文本 15", "tooltip": "输入文本 15" },
      "string_16": { "name": "文本 16", "tooltip": "输入文本 16" },
      "string_17": { "name": "文本 17", "tooltip": "输入文本 17" },
      "string_18": { "name": "文本 18", "tooltip": "输入文本 18" },
      "string_19": { "name": "文本 19", "tooltip": "输入文本 19" },
      "string_20": { "name": "文本 20", "tooltip": "输入文本 20" },
      "input_count": { "name": "接入数量", "tooltip": "修改接入提示词的数量。使用时先修改数量，再点击底部的【修改提示词接入数量】。" },
      "preset_sep": {
        "name": "预设分隔符",
        "tooltip": "选择一个预设分隔符。若自定义分隔符不为空，则此选项被忽略。（不区分中英文：,=，.=。）"
      },
      "custom_sep": { "name": "自定义分隔符", "tooltip": "输入自定义分隔符。若此项不为空，则使用此分隔符。" },
      "remove_newlines": { "name": "移除换行符", "tooltip": "移除换行符" },
      "remove_empty_lines": { "name": "移除空行", "tooltip": "移除空行" },
      "sep_as_segment": { "name": "分隔符独立成段", "tooltip": "如果勾选，合并后的每个【提示词输入框】片段将由换行符 + 分隔符 + 换行符连接。此时，输入框内部的分隔符将不会被用于拆分。如果分隔符本身是换行，则使用双换行符连接（\\n\\n）。" }
    },
    "outputs": {
      "0": { "name": "字符串", "tooltip": "合并后的字符串" }
    }
  },
  "SK_PointIndexer": {
    "display_name": "SK 点位编号器",
    "inputs": {
      "image": { "name": "图片", "tooltip": "输入图片" },
      "points_data": { "name": "点位数据", "tooltip": "点位 JSON" }
    },
    "outputs": {
      "0": { "name": "图片", "tooltip": "标注后的图片" },
      "1": { "name": "JSON 点位", "tooltip": "点位 JSON" }
    }
  },
  "SK_InteractiveEditor": {
    "display_name": "SK 交互编辑器",
    "inputs": {
      "image": { "name": "图片", "tooltip": "输入图片" },
      "points_data": { "name": "点位数据", "tooltip": "点位 JSON" },
      "mask_data": { "name": "遮罩数据", "tooltip": "遮罩数据" }
    },
    "outputs": {
      "0": { "name": "图片组", "tooltip": "合成图片组" },
      "1": { "name": "遮罩", "tooltip": "遮罩" },
      "2": { "name": "涂鸦图片", "tooltip": "涂鸦图片" },
      "3": { "name": "点位图片", "tooltip": "点位图片" },
      "4": { "name": "JSON 点位", "tooltip": "点位 JSON" }
    }
  }
